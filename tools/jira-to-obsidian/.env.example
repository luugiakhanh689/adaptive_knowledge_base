# Copy file này thành .env.local rồi điền giá trị. KHÔNG commit .env.local.
# Token chỉ nằm trong .env.local — không dán vào chat.

# ── Kết nối Jira ──────────────────────────────────────────────────────────
JIRA_BASE_URL=https://jira.company.vn

# XÁC THỰC — chọn đúng loại Jira:
#  A) Jira Server / Data Center (tự host, vd https://jira.company.vn):
#     chỉ cần JIRA_PAT (Personal Access Token). Để JIRA_EMAIL trống.
#     Tạo PAT: avatar (góc phải) > Profile > Personal Access Tokens > Create token > copy.
#  B) Jira Cloud / Atlassian (https://<tên>.atlassian.net):
#     cần JIRA_EMAIL (email tài khoản) + JIRA_PAT là API token.
#     Tạo token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=
JIRA_PAT=PASTE_TOKEN_MOI_VAO_DAY
# auto = tự nhận (URL atlassian.net hoặc có JIRA_EMAIL → Cloud). Ép: cloud | server
JIRA_AUTH_MODE=auto

# ── Nơi lưu kết quả ───────────────────────────────────────────────────────
# OBSIDIAN_VAULT = thư mục script tạo notes vào (chính là vault mở trong Obsidian).
# Mặc định ../../Project_Name_Brain = vault của project này (tương đối từ thư mục tool).
# Lúc setup, Claude đổi tên theo project thật: <TênProject>_Brain.
# Có thể dùng đường dẫn tuyệt đối, vd: /Users/ten-ban/Documents/MyVault
OBSIDIAN_VAULT=../../Project_Name_Brain

# ── Phạm vi quét ──────────────────────────────────────────────────────────
# Để trống = quét mọi project account thấy được. Ví dụ: PROJECT_KEYS=PROJ,SHOP
PROJECT_KEYS=
# true = mỗi project Jira một thư mục con trong vault (PROJ/02_Epics/...). 00_Index +
# _system vẫn dùng chung. Khuyến nghị bật khi quét nhiều project.
GROUP_BY_PROJECT=true

# ── Tùy chọn nâng cao (để trống nếu không cần) ────────────────────────────
# Đổi tên thư mục trong vault — JSON, chỉ điền key muốn đổi.
# Key: index, projects, epic, story, user_story, task, bug, sub-task, raw, system
# Vd: VAULT_DIRS={"epic":"Epics","user_story":"Stories","index":"_MucLuc"}
VAULT_DIRS=

# Jira đặt tên loại issue khác chuẩn (vd tiếng Việt) → mapping JSON (substring, không phân biệt hoa thường).
# Loại chuẩn: epic | user_story | task | bug | sub-task
# Vd: JIRA_TYPE_MAP={"câu chuyện":"user_story","sử thi":"epic","lỗi":"bug","công việc":"task"}
JIRA_TYPE_MAP=

# Mẫu tên thư mục mỗi project (khi GROUP_BY_PROJECT=true). {key}=mã, {name}=tên.
# Mặc định {key}_{name} → PROJ_MyApp. Khác: {name} → MyApp | {key} → FA
PROJECT_FOLDER_PATTERN=

# Custom field id cho Acceptance Criteria / Business Rule nếu Jira có (vd customfield_10101)
JIRA_AC_FIELD=
JIRA_BR_FIELD=
